// Método para abrir el formulario de edición
private void abrirFormularioEdicion(String codigoProducto) {
    try {
        // Declaro la variable para la forma de ABC Productos
        H_AgregarProducto2 frmProductosABC = new H_AgregarProducto2(null, true);

        // Muestra la Forma
        frmProductosABC.setTitle(frmProductosABC.getTitle() + " - Editar");
        frmProductosABC.setCodigo(codigoProducto);
        frmProductosABC.fnBoolProductoExiste(true);
        frmProductosABC.desHabilitarTxtCodigoProducto();
        frmProductosABC.desHabilitarDatos();
        frmProductosABC.BloquearBtnLimpiar();
        frmProductosABC.setVisible(true);

        // Opcional: Refrescar las tarjetas después de editar
       // refrescarTarjetas();

    } catch (SQLException ex) {
        Logger.getLogger(F_Menu_producto.class.getName()).log(Level.SEVERE, null, ex);
        oFunc.SubSistemaMensaje("Error al abrir el formulario de edición");
    }
