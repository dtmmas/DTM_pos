//Método para convertir bytes a ImageIcon
private ImageIcon bytesToImageIcon(byte[] imagenBytes) {
    if (imagenBytes == null || imagenBytes.length == 0) {
        return null;
    }
    
    try {
        // Método más directo y confiable
        ByteArrayInputStream bis = new ByteArrayInputStream(imagenBytes);
        Image imagen = ImageIO.read(bis);
        bis.close();
        
        if (imagen != null) {
            return new ImageIcon(imagen);
        }
    } catch (Exception e) {
        System.out.println("Error convirtiendo bytes a imagen: " + e.getMessage());
        e.printStackTrace();
    }
    return null;
}

//Actualizar crearLabelImagen
private JLabel crearLabelImagen(Producto producto) {
    JLabel labelImagen = new JLabel();
    labelImagen.setHorizontalAlignment(SwingConstants.CENTER);
    labelImagen.setVerticalAlignment(SwingConstants.CENTER);
    labelImagen.setPreferredSize(new Dimension(180, 100)); // Tamaño fijo para la imagen
    labelImagen.setMinimumSize(new Dimension(180, 100));
    labelImagen.setOpaque(true);
    labelImagen.setBackground(new Color(245, 245, 245)); // Fondo gris claro
    labelImagen.setBorder(BorderFactory.createCompoundBorder(
        BorderFactory.createLineBorder(new Color(220, 220, 220), 1),
        BorderFactory.createEmptyBorder(2, 2, 2, 2)
    ));
    
    System.out.println("Cargando imagen para: " + producto.getStrProductoNombre());
    System.out.println("Bytes de imagen: " + (producto.getImagen() != null ? producto.getImagen().length : "null"));
    
    // Cargar imagen desde bytes de la base de datos
    ImageIcon imagenProducto = null;
    if (producto.getImagen() != null && producto.getImagen().length > 100) { // Mínimo 100 bytes para ser una imagen válida
        imagenProducto = bytesToImageIcon(producto.getImagen());
        System.out.println("Imagen convertida: " + (imagenProducto != null ? "ÉXITO" : "FALLÓ"));
    }
    
    if (imagenProducto != null) {
        // Redimensionar la imagen manteniendo aspect ratio
        Image imgOriginal = imagenProducto.getImage();
        int anchoOriginal = imgOriginal.getWidth(null);
        int altoOriginal = imgOriginal.getHeight(null);
        
        System.out.println("Dimensiones originales: " + anchoOriginal + "x" + altoOriginal);
        
        // Calcular nuevo tamaño manteniendo proporción
        int maxAncho = 160;
        int maxAlto = 80;
        
        int nuevoAncho = anchoOriginal;
        int nuevoAlto = altoOriginal;
        
        if (anchoOriginal > maxAncho) {
            nuevoAncho = maxAncho;
            nuevoAlto = (altoOriginal * maxAncho) / anchoOriginal;
        }
        
        if (nuevoAlto > maxAlto) {
            nuevoAlto = maxAlto;
            nuevoAncho = (anchoOriginal * maxAlto) / altoOriginal;
        }
        
        System.out.println("Dimensiones redimensionadas: " + nuevoAncho + "x" + nuevoAlto);
        
        // Redimensionar la imagen
        Image imgRedimensionada = imgOriginal.getScaledInstance(nuevoAncho, nuevoAlto, Image.SCALE_SMOOTH);
        ImageIcon iconoRedimensionado = new ImageIcon(imgRedimensionada);
        
        labelImagen.setIcon(iconoRedimensionado);
        labelImagen.setText(""); // Limpiar texto
        labelImagen.setToolTipText(producto.getStrProductoNombre());
        
    } else {
        // Mostrar placeholder si no hay imagen
        System.out.println("Mostrando placeholder para: " + producto.getStrProductoNombre());
        labelImagen.setIcon(null);
        labelImagen.setText("<html><div style='text-align:center; color: #888; padding: 10px;'>" +
                           "<div style='font-size: 24px;'>📷</div>" +
                           "<div style='font-size: 10px; margin-top: 5px;'>Sin Imagen</div>" +
                           "</div></html>");
        labelImagen.setFont(new Font("Segoe UI", Font.PLAIN, 10));
    }
    
    return labelImagen;
}

//Método mejorado para el diálogo de detalles
private ImageIcon cargarImagenParaDialogo(Producto producto) {
    if (producto.getImagen() != null && producto.getImagen().length > 0) {
        ImageIcon imagenOriginal = bytesToImageIcon(producto.getImagen());
        if (imagenOriginal != null) {
