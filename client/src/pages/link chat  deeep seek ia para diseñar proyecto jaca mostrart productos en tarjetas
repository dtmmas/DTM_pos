            if (cad != null && !cad.isEmpty() && productos != null && !productos.isEmpty()) {
                //busqueda
                Busqueda_avanzada busqueda = new Busqueda_avanzada();
                productosFiltrados = busqueda.findText(cad, productos, Boolean.FALSE);
            } else {
                productosFiltrados = productos;
            }

            llenarTablaConProductos(productosFiltrados);
        } catch (SQLException ex) {
            oFunc.SubSistemaMensaje("sbProductosCargaFiltro:" + ex.getMessage().toString());
        }

    }

private List<Producto> traerTodosProductos() throws SQLException {
    List<Producto> productos = new ArrayList<>();
    
    // Modificar la consulta para filtrar por existencia
    String sQuery = "SELECT * FROM tblProductos WHERE intProductoActual > 0";
    
    System.out.println("Ejecutando consulta: " + sQuery);
    
    //Ejecuta el Query
    oConn.FnBoolQueryExecute(sQuery);

    int contador = 0;
    while (oConn.setResult.next()) {
        // Obtengo los datos en el Objeto Fila
        productos.add(obtenerProductoDeResultadoConsulta(oConn.setResult));
        contador++;
    }
    
    // Cierro los Resultados
    oConn.setResult.close();
    
    System.out.println("Productos con existencia encontrados: " + contador);
    return productos;
}

   private Producto obtenerProductoDeResultadoConsulta(ResultSet resultado) throws SQLException {
    Producto producto = new Producto();
    producto.setStrProductoCodigo(resultado.getString("strProductoCodigo"));
    producto.setStrProductoNombre(resultado.getString("strProductoNombre"));
    producto.setStrProductoDescripcion(resultado.getString("strProductoDescripcion"));
    producto.setStrProductoMedida(resultado.getString("strProductoMedida"));
    producto.setIntProductoInicial(resultado.getString("intProductoInicial"));
    producto.setIntInventariominimo(resultado.getString("intInventariominimo"));
    producto.setIntProductoEntradas(resultado.getString("intProductoEntradas"));
    producto.setIntProductoSalidas(resultado.getString("intProductoSalidas"));
    producto.setIntProductoActual(resultado.getString("intProductoActual"));
    producto.setIntProductoActualBodega(resultado.getString("intProductoActual_bodega")); 
    producto.setDecProductoCosto(resultado.getString("decProductoCosto"));
    producto.setDecProductoPrecio(resultado.getString("decProductoPrecio"));
    producto.setDecProductoPrecio2(resultado.getString("decProductoPrecio2"));
    producto.setDecProductoPrecio3(resultado.getString("decProductoPrecio3"));
    producto.setStrProveedorNombre(resultado.getString("strProveedorNombre"));
    producto.setStrTipoProducto(resultado.getString("strTipoProducto"));
    producto.setStrMarca(resultado.getString("strMarca"));
    producto.setDateVencimiento(resultado.getString("dateVencimiento"));
    producto.setStrComponente(resultado.getString("strComponente"));
    
    // OBTENER IMAGEN DESDE LONGBLOB
    Blob blob = resultado.getBlob("imagen");
    if (blob != null) {
        producto.setImagen(blob.getBytes(1, (int) blob.length()));
    } else {
        producto.setImagen(null);
    }
    
    return producto;
}

    private void limpiarTabla(JTable tabla) {
        DefaultTableModel tblDatos = (DefaultTableModel) tabla.getModel();
        tblDatos.setRowCount(0);
    }

    private void llenarTablaConProductos(List<Producto> productos) {
        //modelo
        DefaultTableModel tblDatos = (DefaultTableModel) tblProductos.getModel();
        if (productos != null && !productos.isEmpty()) {
            productos.stream().forEach(producto -> tblDatos.addRow(obtenerFilaProducto(producto)));
        }

        // Coloca el Modelo de Nueva Cuenta
        tblProductos.setModel(tblDatos);
    }

