private void mostrarVistaGrid() {
    System.out.println("=== MOSTRAR VISTA GRID ===");
    
    if (pnlGridContainer == null) {
        System.out.println("ERROR: pnlGridContainer es null");
        return;
    }
    
    // Limpiar container
    pnlGridContainer.removeAll();

    // VERIFICAR que hay productos para mostrar
    if (productosActuales == null || productosActuales.isEmpty()) {
        System.out.println("No hay productos para mostrar en grid");
        JLabel lblVacio = new JLabel("No hay productos para mostrar");
        lblVacio.setHorizontalAlignment(SwingConstants.CENTER);
        lblVacio.setFont(new Font("Dialog", Font.BOLD, 16));
        lblVacio.setForeground(Color.GRAY);
        lblVacio.setPreferredSize(new Dimension(400, 100));
        pnlGridContainer.add(lblVacio);
    } else {
        // MOSTRAR productos (limitado para buen rendimiento)
        int limite = Math.min(100, productosActuales.size()); // Aumentado a 100
        System.out.println("Mostrando " + limite + " de " + productosActuales.size() + " productos en grid");
        
        for (int i = 0; i < limite; i++) {
            Producto producto = productosActuales.get(i);
            JPanel tarjeta = crearTarjetaProducto(producto);
            pnlGridContainer.add(tarjeta);
        }
    }
    
    // ACTUALIZAR
    pnlGridContainer.revalidate();
    pnlGridContainer.repaint();
    
    System.out.println("Grid actualizado - Componentes: " + pnlGridContainer.getComponentCount());
}

private JPanel crearTarjetaProducto(Producto producto) {
    JPanel tarjeta = new JPanel();
    tarjeta.setLayout(new BorderLayout());
    
    // COLOR DE FONDO SUTIL PARA PRODUCTOS CON EXISTENCIA
    Color colorFondo = Color.WHITE;
    int existencia = 0;
    try {
        existencia = Integer.parseInt(producto.getIntProductoActual());
        if (existencia > 0) {
            // Fondo muy sutil verde claro para productos con existencia
            colorFondo = new Color(245, 255, 245);
        }
    } catch (NumberFormatException e) {
        existencia = 0;
    }
    
    // TARJETA MÁS ALTA PARA LA IMAGEN
    tarjeta.setPreferredSize(new Dimension(220, 240));
    tarjeta.setMinimumSize(new Dimension(200, 230));
    
    // Borde moderno
    tarjeta.setBorder(BorderFactory.createCompoundBorder(
        BorderFactory.createLineBorder(new Color(225, 225, 225), 1),
        BorderFactory.createEmptyBorder(8, 8, 8, 8)
    ));
    
    tarjeta.setBackground(colorFondo);
    tarjeta.setOpaque(true);

    // PANEL SUPERIOR PARA LA IMAGEN (MÁS GRANDE)
    JPanel panelImagen = new JPanel(new BorderLayout());
    panelImagen.setPreferredSize(new Dimension(200, 110));
    panelImagen.setBackground(new Color(245, 245, 245));
    
    // Cargar y mostrar la imagen
    JLabel lblImagen = crearLabelImagen(producto);
    panelImagen.add(lblImagen, BorderLayout.CENTER);
    
    // PANEL INFERIOR PARA LA INFORMACIÓN
    JPanel panelInfo = new JPanel(new GridBagLayout());
    panelInfo.setBackground(colorFondo);
    GridBagConstraints gbc = new GridBagConstraints();
    gbc.fill = GridBagConstraints.HORIZONTAL;
    gbc.anchor = GridBagConstraints.NORTHWEST;
    gbc.weightx = 1.0;
    gbc.insets = new Insets(3, 3, 3, 3);

    // Nombre del producto
    gbc.gridx = 0;
    gbc.gridy = 0;
    JLabel lblNombre = new JLabel("<html><div style='text-align:center; width: 180px;'>" + 
                                 truncarTexto(producto.getStrProductoNombre(), 24) + "</div></html>");
    lblNombre.setFont(new Font("Segoe UI", Font.BOLD, 11));
    lblNombre.setHorizontalAlignment(SwingConstants.CENTER);
    panelInfo.add(lblNombre, gbc);

    // Precio destacado
    gbc.gridy++;
    JLabel lblPrecio = new JLabel("<html><div style='text-align:center; color: #2E86AB;'><b>Q" + 
                                 producto.getDecProductoPrecio() + "</b></div></html>");
    lblPrecio.setFont(new Font("Segoe UI", Font.BOLD, 13));
    lblPrecio.setHorizontalAlignment(SwingConstants.CENTER);
    panelInfo.add(lblPrecio, gbc);

    // Badge de existencia
    gbc.gridy++;
    JLabel lblBadgeExistencia = new JLabel();
    String colorFondoBadge = "#dc3545"; // Rojo por defecto (sin existencia)
    String colorTextoBadge = "white";
    
    if (existencia > 10) {
        colorFondoBadge = "#28a745"; // Verde para buena existencia
        colorTextoBadge = "white";
    } else if (existencia > 0) {
        colorFondoBadge = "#ffc107"; // Amarillo para existencia baja
        colorTextoBadge = "black";
    }
    
    lblBadgeExistencia.setText("<html><div style='background: " + colorFondoBadge + "; color: " + colorTextoBadge + 
                              "; padding: 3px 8px; border-radius: 12px; font-size: 9px; font-weight: bold;'>" +
                              "🏪 " + existencia + " unidades</div></html>");
    lblBadgeExistencia.setHorizontalAlignment(SwingConstants.CENTER);
    panelInfo.add(lblBadgeExistencia, gbc);

    // Información secundaria compacta
    gbc.gridy++;
    JPanel panelSecundario = new JPanel(new FlowLayout(FlowLayout.CENTER, 8, 0));
    panelSecundario.setBackground(colorFondo);
    
    // Código corto si es posible
    String codigo = producto.getStrProductoCodigo();
    if (codigo.length() > 8) {
        codigo = codigo.substring(0, 8) + "...";
    }
    
    JLabel lblCodigo = new JLabel("🔖 " + codigo);
    lblCodigo.setFont(new Font("Segoe UI", Font.PLAIN, 8));
    lblCodigo.setForeground(new Color(86, 98, 112));
    panelSecundario.add(lblCodigo);
    
    panelInfo.add(panelSecundario, gbc);

    // Botón de detalles
    gbc.gridy++;
    gbc.insets = new Insets(8, 0, 0, 0);
    JButton btnDetalles = new JButton("Ver Detalles");
    btnDetalles.setFont(new Font("Segoe UI", Font.PLAIN, 9));
    btnDetalles.setBackground(new Color(74, 144, 226));
    btnDetalles.setForeground(Color.WHITE);
    btnDetalles.setBorder(BorderFactory.createEmptyBorder(6, 12, 6, 12));
    btnDetalles.setFocusPainted(false);
    btnDetalles.setCursor(new Cursor(Cursor.HAND_CURSOR));
    btnDetalles.addActionListener(e -> mostrarDetallesProducto(producto));
    
    // Efecto hover para el botón
    btnDetalles.addMouseListener(new java.awt.event.MouseAdapter() {
        public void mouseEntered(java.awt.event.MouseEvent evt) {
            btnDetalles.setBackground(new Color(65, 131, 215));
        }
        public void mouseExited(java.awt.event.MouseEvent evt) {
            btnDetalles.setBackground(new Color(74, 144, 226));
        }
    });
    
    // Centrar el botón
    JPanel panelBoton = new JPanel(new FlowLayout(FlowLayout.CENTER, 0, 0));
    panelBoton.setBackground(colorFondo);
    panelBoton.add(btnDetalles);
    panelInfo.add(panelBoton, gbc);

    // Agregar todos los paneles a la tarjeta
    tarjeta.add(panelImagen, BorderLayout.NORTH);
    tarjeta.add(panelInfo, BorderLayout.CENTER);
    
    return tarjeta;
}  
    
// Truncar texto largo
 private String truncarTexto(String texto, int longitud) {
        if (texto == null) return "";
        if (texto.length() <= longitud) return texto;
        return texto.substring(0, longitud) + "...";
    }

